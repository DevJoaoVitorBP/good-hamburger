@page "/"

<PageTitle>Home</PageTitle>

<div class="mb-4">
    <h1 class="display-6 mb-2">Good Hamburger</h1>
    <p class="text-muted mb-0">Order management dashboard for menu consultation, order creation, updates, and tracking.</p>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Welcome</h5>
                <p class="card-text">
                    This application provides a complete workflow for managing snack bar orders with automatic discount rules,
                    business validations, and clear operation feedback.
                </p>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a class="btn btn-primary" href="orders">Manage Orders</a>
                    <a class="btn btn-outline-secondary" href="menu">View Menu</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Highlights</h5>
                <ul class="mb-0 ps-3">
                    <li>Full order CRUD</li>
                    <li>Automatic discount calculation</li>
                    <li>Business rule validation</li>
                    <li>API integration with Blazor</li>
                </ul>
            </div>
        </div>
    </div>
</div>
